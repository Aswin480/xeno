# ==============================================================================
# Xeno Copilot Monorepo Environment Variables Example
# ==============================================================================

# --- CRM SERVICE CONFIG ---
PORT=8000
DATABASE_URL="file:./dev.db"
GEMINI_API_KEY_PRIMARY=""
GEMINI_API_KEY_SECONDARY=""

# --- CHANNEL SIMULATOR CONFIG ---
SIMULATOR_PORT=8001
SIMULATOR_LATENCY_MIN=500
SIMULATOR_LATENCY_MAX=2000
SIMULATOR_FAILURE_RATE=0.10 # 10% chance of transmission failure

# --- FRONTEND CONFIG ---
VITE_API_URL="http://localhost:8000"
VITE_SIMULATOR_URL="http://localhost:8001"
